# =============================================
# Gymmix — Global .gitignore
# =============================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment Variables (NEVER commit these)
.env
.env.local
.env.development
.env.production
.env.test
*.env

# Build Outputs
dist/
build/
out/
.next/
.nuxt/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Cache
.cache/
.parcel-cache/
.vite/
.eslintcache
.stylelintcache

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov
.nyc_output/

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# TypeScript
*.tsbuildinfo

# Optional npm cache
.npm/

# Yarn
.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Uploads (local)
uploads/
temp/
tmp/

# SSL Certificates
*.pem
*.key
*.crt
